# App Settings
APP_NAME="KORTA API"
APP_VERSION="1.0.0"
DEBUG=True

# Database
# Local (fora do docker): postgresql://korta_user:korta_pass@localhost:5432/korta_db
# Docker: postgresql://korta_user:korta_pass@db:5432/korta_db
DATABASE_URL=postgresql://korta_user:korta_pass@localhost:5432/korta_db

# Security
SECRET_KEY=muda-esta-chave-em-producao-super-secreta
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# External Services (Optional)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
GOOGLE_MAPS_API_KEY=

# CORS
ALLOWED_ORIGINS=["http://localhost:8081", "http://localhost:3000"]
