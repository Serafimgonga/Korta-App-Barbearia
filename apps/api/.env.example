# App Settings
APP_NAME="KORTA API"
APP_VERSION="1.0.0"
DEBUG=True

# Database
# Local (fora do docker): postgresql://korta_user:korta_pass@localhost:5432/korta_db
# Docker: postgresql://korta_user:korta_pass@db:5432/korta_db
DATABASE_URL=postgresql://korta_user:korta_pass@localhost:5432/korta_db

# Security
SECRET_KEY=sua-chave-secreta-aqui
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# External Services (Optional)
CLOUDINARY_CLOUD_NAME=seu_cloud_name
CLOUDINARY_API_KEY=sua_api_key
CLOUDINARY_API_SECRET=seu_api_secret
GOOGLE_MAPS_API_KEY=sua_chave_google_maps

# CORS
ALLOWED_ORIGINS=["http://localhost:8081", "http://localhost:3000"]
